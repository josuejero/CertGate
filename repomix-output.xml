    <script>
      const reportPaths = {
        release: "reports/release_decision.json",
        validation: "reports/validation_summary.json",
        defects: "reports/defect_summary.json",
      };

      const friendlyCauses = {
        schema_issue: "Schema issues",
        integrity_issue: "Integrity",
        stale_data: "Freshness",
        duplicate_record: "Duplicate records",
        invalid_business_rule_state: "Business rule drift",
      };

      function getTimestampLabel(timestamp) {
        try {
          return new Date(timestamp).toLocaleString(undefined, {
            dateStyle: "medium",
            timeStyle: "short",
          });
        } catch (error) {
          return timestamp || "n/a";
        }
      }

      async function fetchJson(path) {
        const response = await fetch(path);
        if (!response.ok) {
          throw new Error(`Failed to load ${path}: ${response.status}`);
        }
        return response.json();
      }

      function renderStatus(decision, validation) {
        const statusText = document.getElementById("status-text");
        const statusPill = document.getElementById("status-pill");
        statusText.textContent = decision.status;
        statusPill.textContent = decision.status;
        statusPill.dataset.status = decision.status.toLowerCase();
        document.getElementById("status-reason").textContent = decision.decision_reason;
        document.getElementById("status-timestamp").textContent = `Run: ${getTimestampLabel(
          decision.timestamp
        )}`;
        const failList = document.getElementById("fail-list");
        failList.innerHTML = "";
        if (!decision.failed_rules.length) {
          failList.innerHTML = "<li>No blocking defects.</li>";
        } else {
          decision.failed_rules.forEach((rule) => {
            const li = document.createElement("li");
            li.textContent = `${rule.rule_id} (${rule.severity}): ${rule.root_cause}`;
            failList.appendChild(li);
          });
        }
        document.getElementById("rule-count").textContent = validation.rule_count;
        document.getElementById("failed-count").textContent = validation.failed_count;
        document.getElementById("generated-at").textContent = getTimestampLabel(validation.generated_at);
      }

      function renderDefects(defectData) {
        const tbody = document.getElementById("defect-table-body");
        tbody.innerHTML = "";
        if (!defectData.defects.length) {
          tbody.innerHTML = "<tr><td colspan=5>No defects found.</td></tr>";
        } else {
          for (const defect of defectData.defects) {
            const row = document.createElement("tr");
            row.innerHTML = `
            <td>${defect.rule_id}</td>
            <td>${defect.severity}</td>
            <td>${defect.description}</td>
            <td>${friendlyCauses[defect.root_cause] || defect.root_cause}</td>
            <td><a href="${defect.remediation_link}" target="_blank">rule matrix</a></td>
          `;
            tbody.appendChild(row);
          }
        }
        const legend = document.getElementById("defect-legend");
        legend.innerHTML = "";
        if (defectData.root_cause_counts) {
          Object.entries(defectData.root_cause_counts).forEach(([key, value]) => {
            const pill = document.createElement("span");
            pill.className = "legend-pill";
            pill.textContent = `${friendlyCauses[key] || key}: ${value}`;
            legend.appendChild(pill);
          });
        }
      }

      document.addEventListener("DOMContentLoaded", () => {
        const currentUrl = window.location.href;
        const demoLink = document.getElementById("demo-link");
        demoLink.href = currentUrl;
        document.getElementById("demo-url").textContent = currentUrl;

        Promise.all([
          fetchJson(reportPaths.release),
          fetchJson(reportPaths.validation),
          fetchJson(reportPaths.defects),
        ])
          .then(([decision, validation, defects]) => {
            renderStatus(decision, validation);
            renderDefects(defects);
          })
          .catch((error) => {
            console.error(error);
            document.getElementById("status-text").textContent = "Artifacts pending";
            document.getElementById("status-reason").textContent =
              "Run the workflow to populate the demo payloads.";
          });
      });
    </script>
  </body>
</html>
